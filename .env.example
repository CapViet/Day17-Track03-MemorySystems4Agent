# Copy to `.env` and fill in for the provider you want the LIVE path to use.
# Tests and benchmark.py run fully offline (force_offline=True) and need NONE of this.
#
# Pick ONE provider via LLM_PROVIDER, then set its matching key / URL below.
# Install the matching SDK: langchain-openai | langchain-anthropic |
# langchain-google-genai | langchain-ollama  (imports are lazy, so you only
# need the SDK for the provider you actually select).

LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:3b
LLM_TEMPERATURE=0.2

# --- OpenAI ---------------------------------------------------------------
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...

# --- Anthropic ------------------------------------------------------------
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_API_KEY=sk-ant-...

# --- Gemini ---------------------------------------------------------------
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-1.5-flash
# GEMINI_API_KEY=...

# --- OpenRouter -----------------------------------------------------------
# LLM_PROVIDER=openrouter
# LLM_MODEL=openai/gpt-4o-mini
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Custom / any OpenAI-compatible endpoint (vLLM, LM Studio, gateway) ----
# LLM_PROVIDER=custom
# LLM_MODEL=your-model-name
# CUSTOM_BASE_URL=https://your-endpoint/v1
# CUSTOM_API_KEY=your-key-or-anything

# --- Ollama (local, no key) -----------------------------------------------
# LLM_PROVIDER=ollama
# LLM_MODEL=qwen2.5:3b
# OLLAMA_BASE_URL=http://localhost:11434

# Optional: a separate judge model (defaults to the same provider/model).
# JUDGE_PROVIDER=openai
# JUDGE_MODEL=gpt-4o-mini

# Compact-memory tuning (optional; sensible defaults in config.py).
# COMPACT_THRESHOLD_TOKENS=700
# COMPACT_KEEP_MESSAGES=4
